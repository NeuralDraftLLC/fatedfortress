# Copy to e2e/.env — never commit secrets.

# Same project as apps/web/.env.local (see env-vars.md)
VITE_SUPABASE_URL=https://YOUR_REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Service role: Auth admin + DB patches for E2E (Dashboard → Settings → API)
SUPABASE_SERVICE_ROLE_KEY=
# Optional alias some setups use:
# SUPABASE_URL=https://YOUR_REF.supabase.co

# Stripe test secret (matches Edge Function secrets for stripe-payment)
STRIPE_SECRET_KEY=sk_test_...

# Host Stripe Connect account (acct_...) — tests patch profiles.stripe_account_id for realistic PI create/capture
E2E_HOST_STRIPE_CONNECT_ACCOUNT=

# Public R2 base (must match VITE_R2_PUBLIC_URL / R2_PUBLIC_BASE_URL)
VITE_R2_PUBLIC_URL=https://pub-xxxxx.r2.dev

# E2E users (email + password). Supabase Auth: enable Email provider with password.
# global-setup creates them and sets host vs contributor roles.
E2E_HOST_EMAIL=host-e2e@example.com
E2E_HOST_PASSWORD=
E2E_CONTRIBUTOR_EMAIL=contributor-e2e@example.com
E2E_CONTRIBUTOR_PASSWORD=

# Optional: override preview URL
# E2E_BASE_URL=http://127.0.0.1:4173
