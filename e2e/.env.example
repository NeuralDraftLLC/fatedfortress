# Copy to e2e/.env --- NEVER commit e2e/.env (it is gitignored).
# Run:  cp e2e/.env.example e2e/.env  then fill in the blanks below.

# -- Supabase ------------------------------------------------------------------
VITE_SUPABASE_URL=https://pfrtxfuuatzgddenyttm.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InBmcnR4ZnV1YXR6Z2RkZW55dHRtIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzY4Mjg0MjcsImV4cCI6MjA5MjQwNDQyN30.4F2E_97ZonYsFKF4ZDz5uIM0KqZUWjOZIrwgPY81G-s
VITE_SUPABASE_STORAGE_URL=https://pfrtxfuuatzgddenyttm.supabase.co/storage/v1

# Service role key --- Auth admin + DB patches for E2E global-setup
# Supabase Dashboard -> Settings -> API -> service_role (secret)
# NEVER expose this in VITE_ vars or the browser.
SUPABASE_SERVICE_ROLE_KEY=FILL_IN_FROM_SUPABASE_DASHBOARD

# -- Stripe --------------------------------------------------------------------
# Must match STRIPE_SECRET_KEY set in Supabase edge function secrets
# Stripe Dashboard -> Developers -> API keys (use test key: sk_test_...)
STRIPE_SECRET_KEY=FILL_IN_FROM_STRIPE_DASHBOARD

# Stripe Connect host account (acct_...) used to patch profiles.stripe_account_id
# so payment PI create/capture tests work realistically.
E2E_HOST_STRIPE_CONNECT_ACCOUNT=FILL_IN_acct_...

# -- E2E test users ------------------------------------------------------------
# global-setup.ts auto-creates these in Supabase Auth on first run.
# Supabase project must have Email provider + password auth enabled.
E2E_HOST_EMAIL=host-e2e@example.com
E2E_HOST_PASSWORD=FILL_IN_STRONG_PASSWORD
E2E_CONTRIBUTOR_EMAIL=contributor-e2e@example.com
E2E_CONTRIBUTOR_PASSWORD=FILL_IN_STRONG_PASSWORD

# -- Optional overrides --------------------------------------------------------
# Uncomment to override the Vite preview URL (default: http://127.0.0.1:4173)
# E2E_BASE_URL=http://127.0.0.1:4173
