# ─────────────────────────────────────────────────────────────────────────────
# supabase/.env.example
#
# These are Supabase Edge Function SECRETS — not Vite env vars.
# DO NOT prefix these with VITE_  (they never touch the browser).
#
# Copy to supabase/.env and fill in real values, OR set them directly
# in your CI / Railway deploy env, OR use the Supabase CLI:
#
#   supabase secrets set KEY=value [--project-ref YOUR_REF]
#
# Full setup notes: /env-vars.md
# ─────────────────────────────────────────────────────────────────────────────

# ── Stripe ──────────────────────────────────────────────────────────────────────
# Used by: stripe-payment, stripe-connect-onboard, stripe-connect-link
# Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...

# ── OpenAI ──────────────────────────────────────────────────────────────────────
# Used by: scope-tasks (GPT-4o — task generation)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── GitHub ───────────────────────────────────────────────────────────────────────
# GITHUB_TOKEN — PAT used by verify-submission to check PR existence
# Scopes required: read:repo
# https://github.com/settings/personal-access-tokens
GITHUB_TOKEN=ghp_...

# GitHub OAuth App credentials — used by github-oauth edge function
# GitHub → Settings → Developer settings → OAuth Apps → your app
# Client ID is also set as VITE_GITHUB_CLIENT_ID in apps/web/.env.local
GITHUB_CLIENT_ID=Ov23li...
GITHUB_CLIENT_SECRET=your_github_oauth_secret_here

# ── Cron secret ──────────────────────────────────────────────────────────────────
# Shared bearer token for internal cron calls
# Used by: auto-release, expire-claims, stripe-payment
# Generate with: openssl rand -hex 32
CRON_SECRET=your_random_64_char_hex_secret_here

# ── VirusTotal ────────────────────────────────────────────────────────────────────
# Used by: asset-sanitizer (malware + steganography scan)
# Free tier: 10–15 req/min. Sign up at https://www.virustotal.com/gui/join-us
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# ── Sentry (optional) ────────────────────────────────────────────────────────────
# Used by: _shared/scope.ts, asset-sanitizer (token usage + error logging)
# Leave blank to disable Sentry in local dev.
# Sentry Dashboard → Project Settings → Client Keys (DSN)
SENTRY_DSN=https://examplePublicKey@o447370.ingest.sentry.io/PROJECT_ID

# ── Railway workers ─────────────────────────────────────────────────────────────
# Used by: asset-sanitizer — must be the public Railway deploy URL
# These are the deployed URLs of railway/glb-turntable and railway/reencode
RAILWAY_GLBTURNTABLE_URL=https://glb-turntable.up.railway.app
RAILWAY_REENCODE_URL=https://reencode.up.railway.app
