# ─────────────────────────────────────────────────────────────────────────────
# railway/reencode/.env.example
#
# Railway automatically injects PORT at runtime — you never need to set it.
# Copy this to .env for local testing only.  Do NOT commit a real .env file.
# ─────────────────────────────────────────────────────────────────────────────

# HTTP port the worker listens on.
# Railway sets this automatically in production (default: 3000 locally).
PORT=3000
