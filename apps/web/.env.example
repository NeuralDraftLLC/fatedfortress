# Copy to .env.local and fill in real values. See /env-vars.md in the repo root.
#
# Supabase (required)
VITE_SUPABASE_URL=https://YOUR_REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# GitHub OAuth — client ID is public; secret stays in Supabase only (github-oauth fn)
VITE_GITHUB_CLIENT_ID=

# Supabase Storage — used for file uploads (tasks + portfolio)
# Get this from: Supabase Dashboard > Storage > fortress bucket > Usage
VITE_SUPABASE_STORAGE_URL=https://YOUR_REF.supabase.co/storage/v1

# Minimax (api.minimax.chat)
# MINIMAX_API_KEY=   # never commit real API keys

# Playwright E2E: show email+password on /login (Supabase must allow email+password)
# VITE_E2E_PASSWORD_LOGIN=true
