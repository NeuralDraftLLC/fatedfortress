# ─────────────────────────────────────────────────────────────────────────────
# apps/web/.env.example
# Copy to .env.local and fill in real values.  See /env-vars.md for full notes.
# NEVER commit .env.local — it is gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (required) ───────────────────────────────────────────────────────
# Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://pfrtxfuuatzgddenyttm.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InBmcnR4ZnV1YXR6Z2RkZW55dHRtIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzY4Mjg0MjcsImV4cCI6MjA5MjQwNDQyN30.4F2E_97ZonYsFKF4ZDz5uIM0KqZUWjOZIrwgPY81G-s

# Supabase Storage base URL — used in net/storage.ts for file uploads
VITE_SUPABASE_STORAGE_URL=https://pfrtxfuuatzgddenyttm.supabase.co/storage/v1

# ── GitHub OAuth (required) ───────────────────────────────────────────────────
# GitHub → Settings → Developer settings → OAuth Apps → your app → Client ID
# The client SECRET is never placed here — set it as a Supabase edge-function secret
# (GITHUB_CLIENT_SECRET) via: supabase secrets set GITHUB_CLIENT_SECRET=...
VITE_GITHUB_CLIENT_ID=FILL_IN_FROM_GITHUB_OAUTH_APP

# ── Stripe (required) ─────────────────────────────────────────────────────────
# Publishable key is safe to expose client-side (starts with pk_)
# Stripe Dashboard → Developers → API keys
VITE_STRIPE_PUBLISHABLE_KEY=FILL_IN_FROM_STRIPE_DASHBOARD

# ── Playwright E2E (local dev only) ───────────────────────────────────────────
# Uncomment to show email+password login form during E2E tests.
# Requires Supabase project to have email+password auth enabled.
# VITE_E2E_PASSWORD_LOGIN=true
