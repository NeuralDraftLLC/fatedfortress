# Copy to .env.local and fill in real values. See /env-vars.md in the repo root.
#
# Supabase (required)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# GitHub OAuth — client ID is public; secret stays in Supabase only (github-oauth fn)
VITE_GITHUB_CLIENT_ID=

# R2 public asset base (must match R2_PUBLIC_BASE_URL in Supabase secrets for r2-upload-url)
VITE_R2_PUBLIC_URL=

# Playwright E2E: show email+password on /login (Supabase must allow email+password)
# VITE_E2E_PASSWORD_LOGIN=true
