# Supabase
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Stripe (test mode only — use sk_test_...)
STRIPE_SECRET_KEY=sk_test_YOUR_KEY

# Two pre-seeded test user IDs (must exist in auth.users + profiles)
# Role: host
TEST_HOST_ID=00000000-0000-0000-0000-000000000001
# Role: contributor (must have contributor_stripe_account_id set)
TEST_CONTRIBUTOR_ID=00000000-0000-0000-0000-000000000002

# Optional: silence verbose output
# SMOKE_QUIET=true
